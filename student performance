        "# Import Libraries\n",
        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# Sample Student Data\n",
        "data = {\n",
        "    \"Student\": [\"Arun\", \"Priya\", \"Kumar\", \"Divya\", \"Ravi\"],\n",
        "    \"Maths\": [85, 90, 45, 70, 35],\n",
        "    \"Science\": [80, 95, 50, 65, 40],\n",
        "    \"English\": [75, 88, 55, 72, 30]\n",
        "}\n",
        "\n",
        "# Create DataFrame\n",
        "df = pd.DataFrame(data)\n",
        "\n",
        "# Calculate Average\n",
        "df[\"Average\"] = (df[\"Maths\"] + df[\"Science\"] + df[\"English\"]) / 3\n",
        "\n",
        "# Grade Calculation\n",
        "def grade(avg):\n",
        "    if avg >= 90:\n",
        "        return \"A\"\n",
        "    elif avg >= 75:\n",
        "        return \"B\"\n",
        "    elif avg >= 50:\n",
        "        return \"C\"\n",
        "    else:\n",
        "        return \"D\"\n",
        "\n",
        "df[\"Grade\"] = df[\"Average\"].apply(grade)\n",
        "\n",
        "# Pass/Fail Status\n",
        "df[\"Status\"] = df[\"Average\"].apply(\n",
        "    lambda x: \"Pass\" if x >= 40 else \"Fail\"\n",
        ")\n",
        "\n",
        "# Topper\n",
        "topper = df.loc[df[\"Average\"].idxmax()]\n",
        "\n",
        "print(\"Student Performance Report\")\n",
        "print(df)\n",
        "\n",
        "print(\"\\nTopper:\")\n",
        "print(topper)\n",
        "\n",
        "# Subject-wise Average\n",
        "subject_avg = df[[\"Maths\", \"Science\", \"English\"]].mean()\n",
        "print(\"\\nSubject Wise Average:\")\n",
        "print(subject_avg)\n",
        "\n",
        "# Bar Chart\n",
        "subject_avg.plot(kind=\"bar\")\n",
        "plt.title(\"Subject Wise Average Marks\")\n",
        "plt.ylabel(\"Marks\")\n",
        "plt.show()\n",
        "\n",
        "# Pie Chart\n",
        "df[\"Status\"].value_counts().plot(\n",
        "    kind=\"pie\",\n",
        "    autopct=\"%1.1f%%\"\n",
        ")\n",
        "plt.title(\"Pass vs Fail\")\n",
        "plt.ylabel(\"\")\n",
        "plt.show()"
